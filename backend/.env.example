APP_NAME=TradeOps AI
ENVIRONMENT=development

DATABASE_URL=postgresql+asyncpg://tradeops:tradeops@localhost:5432/tradeops
REDIS_URL=redis://localhost:6379/0

ALPACA_API_KEY=your_paper_key_here
ALPACA_SECRET_KEY=your_paper_secret_here
ALPACA_PAPER=true
ALPACA_DATA_FEED=iex

TRADING_MODE=paper
RISK_PROFILE=LEVEL_0_CONSERVATIVE
STARTING_CAPITAL=10000
MAX_POSITION_PCT=0.02
MAX_DAILY_LOSS_PCT=0.005
MAX_TOTAL_DRAWDOWN_PCT=0.02
MAX_TRADES_PER_DAY=3
MAX_OPEN_POSITIONS=1

# Alerts (both optional — alerts log silently if not set)
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
ALERT_EMAIL_FROM=you@gmail.com
ALERT_EMAIL_TO=you@gmail.com
ALERT_EMAIL_PASSWORD=your_16_char_app_password